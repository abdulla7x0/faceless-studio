# Pick ONE llm provider and fill in only that key
LLM_PROVIDER=openai          # openai | anthropic | gemini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Free key from https://www.pexels.com/api/ (used only if you don't
# supply your own clips in --clips_dir, or a keyword has no local match)
PEXELS_API_KEY=
